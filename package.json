		"test": "echo tested",
		"prepare": "husky",
		"coverage:report": "nyc report --reporter=html",
		"see-cy-coverage": "open ./coverage/index.html",
		"cypress:open": "cypress open",
		"cypress:run": "cypress run",
		"cache:clean": "npm cache clean && rm -rf .next/cache/webpack && rm -rf out",
		"pre-build": "npm run check-types && npm run lint && npm run cache:clean"
