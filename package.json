	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "NODE_OPTIONS=\"--max-old-space-size=4096\" next start",
		"serve": "next start",
		"lint": "next lint",
		"check-format": "prettier --check .",
		"format": "prettier --config .prettierrc '**/*.ts' '**/*.tsx' '**/*.json' '**/*.css' '**/*.mjs' '**/*.js' --write --ignore-path .gitignore",
		"check-types": "tsc --noEmit --pretty",
		"test-all": "npm run check-format && npm run lint && npm run check-types && npm run build",
